                if table.find(whitelist, enteredKey) then
                    keyValid = true
                    keyFrame:Destroy()
                    Library:Notify({Title = "Key System", Text = "Welcome!", Duration = 3})
                else
                    keyStatus.Text = "Invalid key!"
                end
            end
        end)
