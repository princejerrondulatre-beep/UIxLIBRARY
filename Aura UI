    -- Floating Toggle Button
    function windowObj:CreateFloatingButton(config)
        config = config or {}
        local text = config.Text or "Toggle"
        local image = config.Image or "" -- asset id or ""
        local position = config.Position or UDim2.new(0, 20, 0, 20)

        local floatBtn = Instance.new("TextButton")
        floatBtn.Size = UDim2.new(0, 60, 0, 60)
        floatBtn.Position = position
        floatBtn.BackgroundColor3 = Library.Theme.Accent
        floatBtn.Text = text
        floatBtn.TextColor3 = Library.Theme.Text
        floatBtn.Font = Enum.Font.GothamBold
        floatBtn.TextSize = 16
        floatBtn.BorderSizePixel = 0
        floatBtn.Parent = gui
        applyRounded(floatBtn, 30)

        if image ~= "" then
            local img = Instance.new("ImageLabel")
            img.Size = UDim2.new(1, -10, 1, -10)
            img.Position = UDim2.new(0, 5, 0, 5)
            img.BackgroundTransparency = 1
            img.Image = image
            img.Parent = floatBtn
        end

        -- Make draggable
        local drag, start, startPos
        floatBtn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                drag = true
                start = input.Position
                startPos = floatBtn.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        drag = false
                    end
                end)
            end
        end)
        floatBtn.InputChanged:Connect(function(input)
            if drag and input.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = input.Position - start
                floatBtn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)

        floatBtn.MouseButton1Click:Connect(function()
            if not drag then
                main.Visible = not main.Visible
            end
        end)

        return floatBtn
    end

