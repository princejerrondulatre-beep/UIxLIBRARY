        valueLabel.TextXAlignment = Enum.TextXAlignment.Right
        valueLabel.Parent = frame

        local sliderFrame = Instance.new("Frame")
        sliderFrame.Size = UDim2.new(1, 0, 0, 8)
        sliderFrame.Position = UDim2.new(0, 0, 0, 25)
        sliderFrame.BackgroundColor3 = Library.Theme.ElementBg
        sliderFrame.BorderSizePixel = 0
        sliderFrame.Parent = frame
        applyRounded(sliderFrame, 4)

        local fill = Instance.new("Frame")
        fill.Size = UDim2.new(0, 0, 1, 0)
        fill.BackgroundColor3 = Library.Theme.Accent
        fill.BorderSizePixel = 0
        fill.Parent = sliderFrame
        applyRounded(fill, 4)

        local knob = Instance.new("TextButton")
        knob.Size = UDim2.new(0, 14, 0, 14)
        knob.Position = UDim2.new(0, -7, 0.5, -7)
        knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        knob.Text = ""
        knob.BorderSizePixel = 0
        knob.Parent = sliderFrame
        applyRounded(knob, 7)

        local minVal = config.Min or 0
        local maxVal = config.Max or 100
        local current = config.Default or minVal

        local function setValue(val)
            val = math.clamp(val, minVal, maxVal)
            current = val
            local percent = (val - minVal) / (maxVal - minVal)
            fill.Size = UDim2.new(percent, 0, 1, 0)
            valueLabel.Text = string.format("%.1f", val)
            if config.Callback then
                config.Callback(val)
            end
            windowObj.Flags[config.Flag or config.Name] = val
        end

        setValue(current)

        local draggingSlider = false
        knob.MouseButton1Down:Connect(function()
            draggingSlider = true
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                draggingSlider = false
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
                local mousePos = UserInputService:GetMouseLocation()
                local relPos = mousePos - sliderFrame.AbsolutePosition
                local percent = math.clamp(relPos.X / sliderFrame.AbsoluteSize.X, 0, 1)
                setValue(minVal + percent * (maxVal - minVal))
            end
        end)
    end

