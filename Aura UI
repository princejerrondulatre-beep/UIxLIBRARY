            sliderFrame.Position = UDim2.new(0, 50, 0, yPos)
            sliderFrame.BackgroundColor3 = Library.Theme.ElementBg
            sliderFrame.BorderSizePixel = 0
            sliderFrame.Parent = frame
            applyRounded(sliderFrame, 4)

            local fill = Instance.new("Frame")
            fill.Size = UDim2.new(0, 0, 1, 0)
            fill.BackgroundColor3 = component == "R" and Color3.fromRGB(255,0,0) or
                                  (component == "G" and Color3.fromRGB(0,255,0) or Color3.fromRGB(0,0,255))
            fill.BorderSizePixel = 0
            fill.Parent = sliderFrame
            applyRounded(fill, 4)

            local knob = Instance.new("TextButton")
            knob.Size = UDim2.new(0, 12, 0, 12)
            knob.Position = UDim2.new(0, -6, 0.5, -6)
            knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
            knob.Text = ""
            knob.BorderSizePixel = 0
            knob.Parent = sliderFrame
            applyRounded(knob, 6)

            return sliderFrame, fill, knob
        end

        local rSlider, rFill, rKnob = createRGBSlider("R", 25)
        local gSlider, gFill, gKnob = createRGBSlider("G", 40)
        local bSlider, bFill, bKnob = createRGBSlider("B", 55)

        local currentColor = config.Default or Color3.fromRGB(255, 0, 0)

        local function updateColor()
            display.BackgroundColor3 = currentColor
            rFill.Size = UDim2.new(currentColor.R, 0, 1, 0)
            gFill.Size = UDim2.new(currentColor.G, 0, 1, 0)
            bFill.Size = UDim2.new(currentColor.B, 0, 1, 0)
            if config.Callback then
                config.Callback(currentColor)
            end
            windowObj.Flags[config.Flag or config.Name] = currentColor
        end

        local function sliderDrag(slider, fill, knob, setFunc)
            local dragging = false
            knob.MouseButton1Down:Connect(function() dragging = true end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local mousePos = UserInputService:GetMouseLocation()
                    local relPos = mousePos - slider.AbsolutePosition
                    local percent = math.clamp(relPos.X / slider.AbsoluteSize.X, 0, 1)
                    setFunc(percent)
                end
            end)
        end

        sliderDrag(rSlider, rFill, rKnob, function(percent)
            currentColor = Color3.new(percent, currentColor.G, currentColor.B)
            updateColor()
        end)
        sliderDrag(gSlider, gFill, gKnob, function(percent)
            currentColor = Color3.new(currentColor.R, percent, currentColor.B)
            updateColor()
        end)
        sliderDrag(bSlider, bFill, bKnob, function(percent)
            currentColor = Color3.new(currentColor.R, currentColor.G, percent)
            updateColor()
        end)

        updateColor()
    end

    function windowObj:Dropdown(config)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, -20, 0, 40)
        frame.BackgroundTransparency = 1
        frame.Parent = content

        local label = Instance.new("TextLabel")
        label.Text = config.Name or "Dropdown"
        label.Size = UDim2.new(1, 0, 0, 20)
        label.BackgroundTransparency = 1
        label.TextColor3 = Library.Theme.Text
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Font = Enum.Font.Gotham
        label.TextSize = 14
        label.Parent = frame

        local mainBtn = Instance.new("TextButton")
        mainBtn.Size = UDim2.new(1, 0, 0, 25)
        mainBtn.Position = UDim2.new(0, 0, 0, 20)
        mainBtn.Text = config.Default or "Select..."
        mainBtn.BackgroundColor3 = Library.Theme.ElementBg
        mainBtn.TextColor3 = Library.Theme.Text
        mainBtn.Font = Enum.Font.Gotham
        mainBtn.TextSize = 14
        mainBtn.TextXAlignment = Enum.TextXAlignment.Left
        mainBtn.BorderSizePixel = 0
        mainBtn.Parent = frame
        applyRounded(mainBtn, 4)

        local arrow = Instance.new("TextLabel")
        arrow.Text = "▼"
        arrow.Size = UDim2.new(0, 20, 1, 0)
        arrow.Position = UDim2.new(1, -20, 0, 0)
        arrow.BackgroundTransparency = 1
        arrow.TextColor3 = Library.Theme.Text
        arrow.Font = Enum.Font.Gotham
        arrow.TextSize = 12
        arrow.Parent = mainBtn

        local options = config.Options or {}
        local dropFrame = Instance.new("Frame")
        dropFrame.Size = UDim2.new(1, 0, 0, #options * 25)
        dropFrame.Position = UDim2.new(0, 0, 1, 2)
        dropFrame.BackgroundColor3 = Library.Theme.ElementBg
        dropFrame.BorderSizePixel = 0
        dropFrame.Visible = false
        dropFrame.ZIndex = 10
        dropFrame.Parent = mainBtn
        applyRounded(dropFrame, 4)

        local selected = config.Default
        local function setSelected(opt)
            selected = opt
            mainBtn.Text = opt
            dropFrame.Visible = false
            if config.Callback then
                config.Callback(opt)
            end
            windowObj.Flags[config.Flag or config.Name] = opt
        end

        for i, opt in ipairs(options) do
            local optBtn = Instance.new("TextButton")
            optBtn.Size = UDim2.new(1, 0, 0, 25)
            optBtn.Position = UDim2.new(0, 0, 0, (i-1)*25)
            optBtn.Text = opt
            optBtn.BackgroundColor3 = Library.Theme.ElementBg
            optBtn.TextColor3 = Library.Theme.Text
            optBtn.Font = Enum.Font.Gotham
            optBtn.TextSize = 14
            optBtn.TextXAlignment = Enum.TextXAlignment.Left
            optBtn.BorderSizePixel = 0
            optBtn.ZIndex = 11
            optBtn.Parent = dropFrame
            optBtn.MouseButton1Click:Connect(function()
                setSelected(opt)
            end)
        end

        mainBtn.MouseButton1Click:Connect(function()
            dropFrame.Visible = not dropFrame.Visible
            frame.Size = UDim2.new(1, -20, 0, dropFrame.Visible and 40 + dropFrame.AbsoluteSize.Y + 5 or 40)
            content.CanvasSize = UDim2.new(0,0,0,content.AbsoluteCanvasSize.Y)
        end)

        -- Close dropdown when clicking elsewhere
        UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local pos = UserInputService:GetMouseLocation()
                if dropFrame.Visible and not (mainBtn.AbsolutePosition.X <= pos.X and pos.X <= mainBtn.AbsolutePosition.X + mainBtn.AbsoluteSize.X and
                    mainBtn.AbsolutePosition.Y <= pos.Y and pos.Y <= mainBtn.AbsolutePosition.Y + mainBtn.AbsoluteSize.Y + dropFrame.AbsoluteSize.Y) then
                    dropFrame.Visible = false
                    frame.Size = UDim2.new(1, -20, 0, 40)
                end
            end
        end)
    end

    return windowObj
end

return Library
