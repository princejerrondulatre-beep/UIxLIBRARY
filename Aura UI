    function windowObj:Keybind(config)
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, -20, 0, 35)
        frame.BackgroundTransparency = 1
        frame.Parent = content

        local label = Instance.new("TextLabel")
        label.Text = config.Name or "Keybind"
        label.Size = UDim2.new(1, -100, 1, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Library.Theme.Text
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Font = Enum.Font.Gotham
        label.TextSize = 14
        label.Parent = frame

        local keyBtn = Instance.new("TextButton")
        keyBtn.Size = UDim2.new(0, 80, 0, 25)
        keyBtn.Position = UDim2.new(1, -80, 0.5, -12)
        keyBtn.Text = config.Default or "None"
        keyBtn.BackgroundColor3 = Library.Theme.ElementBg
        keyBtn.TextColor3 = Library.Theme.Text
        keyBtn.Font = Enum.Font.GothamBold
        keyBtn.TextSize = 12
        keyBtn.BorderSizePixel = 0
        keyBtn.Parent = frame
        applyRounded(keyBtn, 4)

        local currentKey = config.Default
        local listening = false
        local connection

        keyBtn.MouseButton1Click:Connect(function()
            listening = true
            keyBtn.Text = "..."
            if connection then connection:Disconnect() end
            connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if not listening or gameProcessed then return end
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    currentKey = input.KeyCode.Name
                elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
                    currentKey = "LeftClick"
                elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
                    currentKey = "RightClick"
                else
                    return
                end
                keyBtn.Text = currentKey
                listening = false
                connection:Disconnect()
                if config.Callback then
                    config.Callback(currentKey)
                end
                windowObj.Flags[config.Flag or config.Name] = currentKey
            end)
        end)

        -- Actual keybind execution
        local execConn
        local function updateExecution()
            if execConn then execConn:Disconnect() end
            execConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if gameProcessed then return end
                local match = false
                if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == currentKey then
                    match = true
                elseif input.UserInputType == Enum.UserInputType.MouseButton1 and currentKey == "LeftClick" then
                    match = true
                elseif input.UserInputType == Enum.UserInputType.MouseButton2 and currentKey == "RightClick" then
                    match = true
                end
                if match and config.Callback then
                    config.Callback()
                end
            end)
        end
        updateExecution()
        windowObj.Connections[config.Name] = execConn
    end

