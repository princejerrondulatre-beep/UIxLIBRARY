-- Utility Functions
local function Create(Class, Properties)
    local Instance = Instance.new(Class)
    for Property, Value in next, Properties do
        Instance[Property] = Value
    end
    return Instance
end

local function Tween(Object, Goal, Duration, Style, Direction, Callback)
    Style = Style or Enum.EasingStyle.Quart
    Direction = Direction or Enum.EasingDirection.Out
    local Tween = TweenService:Create(Object, TweenInfo.new(Duration, Style, Direction), Goal)
    Tween:Play()
    if Callback then
        Tween.Completed:Connect(Callback)
    end
    return Tween
end

-- Key System (simple whitelist)
local ValidKeys = {
    "TEST-KEY-123",
    "NEXUS-DEMO"
}

local function CheckKey(InputKey)
    for _, Key in ipairs(ValidKeys) do
        if InputKey == Key then
            return true
        end
    end
    return false
end

-- Notification System
local Notifications = {}
function Library:Notification(Title, Text, Duration)
    Duration = Duration or 3
    local NotificationFrame = Create("Frame", {
        Parent = ScreenGui,
        BackgroundColor3 = CurrentTheme.Element,
        BorderSizePixel = 0,
        Position = UDim2.new(1, -10, 1, -10 - (#Notifications * 55)),
        Size = UDim2.new(0, 250, 0, 50),
        AnchorPoint = Vector2.new(1, 1),
        ClipsDescendants = true
    })
    Create("UICorner", {Parent = NotificationFrame, CornerRadius = UDim.new(0, 6)})
    Create("UIStroke", {
        Parent = NotificationFrame,
        Color = CurrentTheme.Outline,
        Thickness = 1.5
    })
    
    local TitleLabel = Create("TextLabel", {
        Parent = NotificationFrame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 5),
        Size = UDim2.new(1, -20, 0, 18),
        Font = Enum.Font.GothamBold,
        Text = Title,
        TextColor3 = CurrentTheme.Accent,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    local TextLabel = Create("TextLabel", {
        Parent = NotificationFrame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 10, 0, 24),
        Size = UDim2.new(1, -20, 0, 20),
        Font = Enum.Font.Gotham,
        Text = Text,
        TextColor3 = CurrentTheme.Text,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true
    })
    
    table.insert(Notifications, NotificationFrame)
    
    -- Slide in animation
    NotificationFrame.Position = UDim2.new(1, 260, 1, -10 - (#Notifications * 55))
    Tween(NotificationFrame, {Position = UDim2.new(1, -10, 1, -10 - (#Notifications * 55))}, 0.3)
    
    -- Auto remove
    delay(Duration, function()
        Tween(NotificationFrame, {Position = UDim2.new(1, 260, NotificationFrame.Position.Y.Scale, NotificationFrame.Position.Y.Offset)}, 0.3, nil, nil, function()
            NotificationFrame:Destroy()
            for i, v in ipairs(Notifications) do
                if v == NotificationFrame then
                    table.remove(Notifications, i)
                    break
                end
            end
            -- Reposition remaining notifications
            for i, notif in ipairs(Notifications) do
                Tween(notif, {Position = UDim2.new(1, -10, 1, -10 - (i * 55))}, 0.2)
            end
        end)
    end)
end

-- Copy to Clipboard
function Library:CopyToClipboard(Text)
    local success = pcall(function()
        if setclipboard then
            setclipboard(Text)
        else
            local TextBox = Instance.new("TextBox")
            TextBox.Text = Text
            TextBox:CaptureFocus()
            TextBox:ReleaseFocus()
            TextBox:Destroy()
        end
    end)
    if success then
        Library:Notification("Copied", "Text copied to clipboard!", 2)
    else
        Library:Notification("Error", "Failed to copy text.", 2)
    end
end

