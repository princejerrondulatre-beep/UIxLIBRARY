                TextColor3 = CurrentTheme.Accent,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Right
            })
            
            local Expanded = false
            local OptionsHolder = Create("Frame", {
                Parent = DropdownFrame,
                BackgroundColor3 = CurrentTheme.Main,
                BorderSizePixel = 0,
                Position = UDim2.new(0, 0, 1, 2),
                Size = UDim2.new(1, 0, 0, 0),
                Visible = false,
                ClipsDescendants = true,
                ZIndex = 5
            })
            Create("UICorner", {Parent = OptionsHolder, CornerRadius = UDim.new(0, 6)})
            Create("UIStroke", {
                Parent = OptionsHolder,
                Color = CurrentTheme.Outline,
                Thickness = 1.5,
                ZIndex = 6
            })
            
            local OptionButtons = {}
            local function UpdateOptions()
                for _, btn in ipairs(OptionButtons) do btn:Destroy() end
                OptionButtons = {}
                for i, opt in ipairs(Options) do
                    local btn = Create("TextButton", {
                        Parent = OptionsHolder,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 25),
                        Position = UDim2.new(0, 0, 0, (i-1)*25),
                        Font = Enum.Font.Gotham,
                        Text = opt,
                        TextColor3 = CurrentTheme.Text,
                        TextSize = 13,
                        ZIndex = 5
                    })
                    btn.MouseEnter:Connect(function()
                        Tween(btn, {BackgroundColor3 = CurrentTheme.Accent}, 0.1)
                    end)
                    btn.MouseLeave:Connect(function()
                        Tween(btn, {BackgroundColor3 = Color3.fromRGB(255,255,255)}, 0.1, nil, nil, function() btn.BackgroundTransparency = 1 end)
                    end)
                    btn.MouseButton1Click:Connect(function()
                        Selected.Text = opt
                        Callback(opt)
                        Expanded = false
                        OptionsHolder.Visible = false
                        Tween(DropdownFrame, {Size = UDim2.new(1, -10, 0, 40)}, 0.15)
                    end)
                    table.insert(OptionButtons, btn)
                end
                OptionsHolder.Size = UDim2.new(1, 0, 0, #Options * 25)
            end
            UpdateOptions()
            
            DropdownFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    Expanded = not Expanded
                    OptionsHolder.Visible = Expanded
                    Tween(DropdownFrame, {Size = Expanded and UDim2.new(1, -10, 0, 40 + #Options*25) or UDim2.new(1, -10, 0, 40)}, 0.15)
                end
            end)
            
            Page.CanvasSize = UDim2.new(0, 0, 0, Page.UIListLayout.AbsoluteContentSize.Y + 10)
            
            return {
                SetOptions = function(self, NewOptions)
                    Options = NewOptions
                    UpdateOptions()
                end
            }
        end
        
        function Tab:AddKeybind(Name, DefaultKey, Callback)
            DefaultKey = DefaultKey or Enum.KeyCode.E
            local KeybindFrame = Create("Frame", {
                Parent = Page,
                BackgroundColor3 = CurrentTheme.Element,
                BorderSizePixel = 0,
                Size = UDim2.new(1, -10, 0, 35),
                Position = UDim2.new(0, 5, 0, 0)
            })
            Create("UICorner", {Parent = KeybindFrame, CornerRadius = UDim.new(0, 6)})
            Create("UIStroke", {
                Parent = KeybindFrame,
                Color = CurrentTheme.Outline,
                Thickness = 1.5
            })
            
            local Label = Create("TextLabel", {
                Parent = KeybindFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 10, 0, 0),
                Size = UDim2.new(0.6, 0, 1, 0),
                Font = Enum.Font.Gotham,
                Text = Name,
                TextColor3 = CurrentTheme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local KeyButton = Create("TextButton", {
                Parent = KeybindFrame,
                BackgroundColor3 = Color3.fromRGB(40,40,50),
                BorderSizePixel = 0,
                Position = UDim2.new(1, -80, 0.5, -10),
                Size = UDim2.new(0, 70, 0, 20),
                Font = Enum.Font.Gotham,
                Text = tostring(DefaultKey):match("%.(%w+)$"),
                TextColor3 = CurrentTheme.Text,
                TextSize = 13,
                AutoButtonColor = false
            })
            Create("UICorner", {Parent = KeyButton, CornerRadius = UDim.new(0, 4)})
            
            local CurrentKey = DefaultKey
            local Binding = false
            KeyButton.MouseButton1Click:Connect(function()
                Binding = true
                KeyButton.Text = "..."
                local conn
                conn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                    if not gameProcessed and Binding then
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            CurrentKey = input.KeyCode
                            KeyButton.Text = tostring(CurrentKey):match("%.(%w+)$")
                            Callback(CurrentKey)
                            Binding = false
                            conn:Disconnect()
                        end
                    end
                end)
            end)
            
            UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if not gameProcessed and input.KeyCode == CurrentKey and not Binding then
                    Callback(CurrentKey)
                end
            end)
            
            Page.CanvasSize = UDim2.new(0, 0, 0, Page.UIListLayout.AbsoluteContentSize.Y + 10)
            return KeybindFrame
        end
        
        function Tab:AddColorPicker(Name, DefaultColor, Callback)
            local PickerFrame = Create("Frame", {
                Parent = Page,
                BackgroundColor3 = CurrentTheme.Element,
                BorderSizePixel = 0,
                Size = UDim2.new(1, -10, 0, 100),
                Position = UDim2.new(0, 5, 0, 0)
            })
            Create("UICorner", {Parent = PickerFrame, CornerRadius = UDim.new(0, 6)})
            Create("UIStroke", {
                Parent = PickerFrame,
                Color = CurrentTheme.Outline,
                Thickness = 1.5
            })
            
            local Label = Create("TextLabel", {
                Parent = PickerFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 10, 0, 5),
                Size = UDim2.new(1, -20, 0, 18),
                Font = Enum.Font.Gotham,
                Text = Name,
                TextColor3 = CurrentTheme.Text,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local ColorDisplay = Create("Frame", {
                Parent = PickerFrame,
                BackgroundColor3 = DefaultColor or Color3.new(1,0,0),
                BorderSizePixel = 0,
                Position = UDim2.new(0, 10, 0, 28),
                Size = UDim2.new(0, 30, 0, 30)
            })
            Create("UICorner", {Parent = ColorDisplay, CornerRadius = UDim.new(0, 4)})
            
            -- RGB sliders
            local RSlider, GSlider, BSlider
            local function UpdateColor()
                local r = RSlider and RSlider.Value or 1
                local g = GSlider and GSlider.Value or 0
                local b = BSlider and BSlider.Value or 0
                ColorDisplay.BackgroundColor3 = Color3.new(r,g,b)
                Callback(Color3.new(r,g,b))
            end
            
            RSlider = Tab:AddSlider("Red", 0, 1, 1, function(v) UpdateColor() end)
            GSlider = Tab:AddSlider("Green", 0, 1, 0, function(v) UpdateColor() end)
            BSlider = Tab:AddSlider("Blue", 0, 1, 0, function(v) UpdateColor() end)
            
            Page.CanvasSize = UDim2.new(0, 0, 0, Page.UIListLayout.AbsoluteContentSize.Y + 10)
            return PickerFrame
        end
        
        function Tab:AddCopyButton(Name, TextToCopy)
            return Tab:AddButton(Name, function()
                Library:CopyToClipboard(TextToCopy)
            end)
        end
        
        return Tab
    end
    
    return Library
end

-- Theme setter (Fixed)
function Library:SetTheme(ThemeName)
    if Themes[ThemeName] then
        CurrentTheme = Themes[ThemeName]
        Library:Notification("Theme", "Theme set to " .. ThemeName, 2)
    else
        Library:Notification("Theme Error", "Theme '" .. ThemeName .. "' not found.", 2)
    end
end

-- Key System Entry
function NeXus:Init(Options)
    Options = Options or {}
    local Key = Options.Key
    if not CheckKey(Key) then
        Library:Notification("Invalid Key", "The provided key is invalid.", 5)
        return nil
    end
    
    Library:Notification("NeXus", "Welcome to NeXus UI Library!", 3)
    return Library
end

return NeXus
